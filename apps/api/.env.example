# Firebase Configuration
FIREBASE_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id

# Tenant — the clients/{clientId} doc this API instance serves data for.
# Must match the CLIENT_ID set on the same restaurant's dashboard deployment.
CLIENT_ID=your-client-id

# GCIP tenant id for this client (e.g. acme-co-x7k2p).
# Must match the FIREBASE_TENANT_ID set on the same restaurant's dashboard deployment.
FIREBASE_TENANT_ID=your-firebase-tenant-id
